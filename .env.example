# Gemini API — credentials.json (GCP service account) powers Vertex AI
# Get from: https://console.cloud.google.com/ → Credentials → Service Account

# Hotkey combo (default: ctrl+shift+q)
HOTKEY_COMBO=ctrl+shift+q

# PostgreSQL (Docker — run: docker-compose up -d)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=sciurus
POSTGRES_USER=sciurus
POSTGRES_PASSWORD=sciurus_dev
