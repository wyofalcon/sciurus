# Sciurus! — Environment Configuration
# Copy this file to .env and customize.
# cp .env.example .env

# ── Database ──
# Options: pg, sqlite, or auto (tries pg then falls back to sqlite)
DB_BACKEND=auto

# PostgreSQL connection (only needed when DB_BACKEND=pg or auto)
# Docker default: docker compose up -d (uses port 5433 to avoid conflicts)
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_DB=sciurus
POSTGRES_USER=sciurus
POSTGRES_PASSWORD=sciurus_dev

# ── AI (optional) ──
# Options: apikey, vertex, or auto
AI_AUTH_MODE=auto

# Gemini API key (for apikey mode — get free at https://aistudio.google.com/apikey)
# GEMINI_API_KEY=AIzaSy...

# Vertex AI (for vertex mode — save service account JSON as credentials.json in project root)

# ── Capture ──
# Global hotkey combo (default: ctrl+shift+q)
HOTKEY_COMBO=ctrl+shift+q

# ── Development ──
# Set to 1 to auto-open DevTools on launch
# SCIURUS_DEV=1
